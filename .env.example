# --- Database / Cache ---
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=change-me-jwt-signing-key
FERNET_KEY=                       # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Multi-tenancy (always sent as X-Scope-OrgID header) ---
MIMIR_TENANT_ID=system

# --- Observability stack endpoints ---
MIMIR_RULER_URL=http://mimir:8080/prometheus/config/v1/rules
MIMIR_ALERTMANAGER_URL=http://mimir-alertmanager:8080
MIMIR_QUERY_URL=http://mimir:8080/prometheus
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
GRAFANA_URL=http://grafana:3000

# --- OIDC (own SSO) ---
OIDC_ISSUER=https://sso.example.com/realms/main
OIDC_CLIENT_ID=atlas
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback

# --- App ---
APP_ENV=dev
CORS_ORIGINS=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SYNC_INTERVAL_SECONDS=30

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
